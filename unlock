        if hum then
            hum.Health = hum.MaxHealth
        end
    else
        -- [[ CLEAN EFFECT - RESET WHEN OFF ]]
        PlayerMovement.OnCollideBind = true 
        
        -- Only re-enable Sensor if Fly Mode isn't currently using it
        if not Settings.FlyMode then
            PlayerMovement.Sensor = true
        end
    end

  -- [[ INFINITE JUMP - FIXED RESET ]]
    if Settings.InfJump then
        PlayerMovement.RemainingJumps = 999
        PlayerMovement.MaxJump = 999
    else
        -- Restore default values when turned off
        -- Usually, default MaxJump is 1 or 2 depending on the game
        if PlayerMovement.MaxJump == 999 then
            PlayerMovement.MaxJump = 1 
            PlayerMovement.RemainingJumps = 0
        end
    end

    -- [[ FLY MODE LOGIC ]]
    if Settings.FlyMode then
        local isHoldingJump = UserInputService:IsKeyDown(Enum.KeyCode.Space)
        
        if isHoldingJump then
            -- ASCEND
            PlayerMovement.Sensor = false 
            PlayerMovement.VelocityY = Settings.FlySpeed
            -- Boost lift
            if not PlayerMovement.Grounded then
                PlayerMovement.VelocityY = PlayerMovement.VelocityY + 0.38
            end
        else
            -- FALL: Only re-enable sensor if God V2 is also OFF
            if not Settings.GodModeV2 then
                PlayerMovement.Sensor = true 
            end
            
            -- THE FIX: Ensure VelocityY isn't stuck upward
            if not PlayerMovement.Grounded and PlayerMovement.VelocityY > 0 then
                PlayerMovement.VelocityY = 0 
            end
        end
    else
        -- Reset Sensor when Fly is OFF, provided God V2 is also OFF
        if not Settings.GodModeV2 then
            PlayerMovement.Sensor = true
        end
    end

  -- [[ STABLE SPEED HACK BYPASS ]]
if Settings.SpeedHack then
    -- Use a small threshold (0.01) instead of 0 to account for floating point errors during lag
    local isMoving = math.abs(PlayerMovement.MoveX) > 0.01
    
    -- Lagsafe Check: If the internal velocity is already high, keep pushing it
    -- This ensures the speed doesn't "stutter" when your ping spikes
    if isMoving or math.abs(PlayerMovement.VelocityX) > 1 then
        
        -- Normalize MoveX during lag: If MoveX is 0 due to lag but we have Velocity, 
        -- we use the direction of the current Velocity to keep the boost consistent.
        local direction = 0
        if isMoving then
            direction = PlayerMovement.MoveX
        else
            direction = (PlayerMovement.VelocityX > 0) and 1 or -1
        end

        -- Applying the bypass formula: (multiplier * 0.1)
        -- Added math.clamp to prevent physics crashes during extreme lag spikes
        local boost = direction * (Settings.SpeedMultiplier * 0.1)
        PlayerMovement.VelocityX = PlayerMovement.VelocityX + boost
    end
end

    -- [[ 6. ADVANCED ANTI-KNOCKBACK (FIXED) ]]
    -- This runs independently and uses the 0.1 strict threshold
    if Settings.AntiKnockback or Settings.GodModeV2 then
        -- If we aren't pressing MoveX (idle), kill all Horizontal Velocity
        if math.abs(PlayerMovement.MoveX) == 0 then
            if math.abs(PlayerMovement.VelocityX) > 0.1 then
                PlayerMovement.VelocityX = 0
            end
        end
        
        -- Kill all Vertical Velocity (Stops you from being launched up)
        -- Only triggers if you aren't flying or jumping
        if not Settings.FlyMode and not Settings.InfJump then
            if PlayerMovement.VelocityY > 0.1 then
                 PlayerMovement.VelocityY = 0
            end
        end
    end
end)

