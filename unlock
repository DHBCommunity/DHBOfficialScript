local isDropping = false
local dropDebounce = false 

ToggleBtn.MouseButton1Click:Connect(function()
    if dropDebounce then return end 
    
    if isDropping then 
        isDropping = false 
        return 
    end

    local totalStr = AmountInput.Text:gsub(",", "")
    local total = tonumber(totalStr)
    if not total or total <= 0 then 
        AmountInput.Text = "Invalid Amt"
        task.wait(0.5)
        AmountInput.Text = "1000"
        return 
    end

    -- Identify target item from current selection
    local selected = InvModule.SelectedHotbar
    if typeof(selected) ~= "number" then return end
    local stackIndices = InvModule.HotbarStacks[selected]
    if not stackIndices or #stackIndices == 0 then return end
    
    local targetStack = InvModule.Stacks[stackIndices[1]]
    if not targetStack or not targetStack.Id then return end
    local targetItemId = targetStack.Id

    isDropping = true
    dropDebounce = true
    ToggleBtn.Text = "CANCEL DROP"
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
    task.wait(0.1)
    dropDebounce = false

    task.spawn(function()
        local sessionDropped = 0
        local remainingToDrop = total

        while isDropping and remainingToDrop > 0 do
            -- 1. Locate the item accurately
            local currentSlot = nil
            for i, stack in pairs(InvModule.Stacks) do
                if stack and stack.Id == targetItemId and stack.Amount > 0 then
                    currentSlot = i
                    break
                end
            end

            if not currentSlot then break end
            
            local inventoryTotal = getTotalHoldingAmount(targetItemId)
            local chunk = math.min(remainingToDrop, 200, inventoryTotal)
            if chunk <= 0 then break end

            -- 2. Open Menu & Wait for UI Confirmation
            PlayerDropRemote:FireServer(currentSlot)
            
            -- This loop ensures the UI is actually ready before we "Fire" the drop
            local timeout = 0
            repeat 
                task.wait() 
                timeout = timeout + 1
            until PlayerGui:FindFirstChild("UIPromptUI") or timeout > 20
            
            if not isDropping then break end

            -- 3. Execute Drop
            local dropArgs = {
                [1] = {
                    ["ButtonAction"] = "drp",
                    ["Inputs"] = { ["amt"] = tostring(chunk) }
                }
            }
            PromptEvent:FireServer(unpack(dropArgs))
            
            -- 4. Verify & Update Stats
            sessionDropped = sessionDropped + chunk
            remainingToDrop = remainingToDrop - chunk
            
            RemainingVal.Text = tostring(math.max(0, remainingToDrop))
            DroppedVal.Text = tostring(sessionDropped)
            
            -- 5. Reliable Cleanup
            task.wait(0.05)
            forceCleanExit()
            
            -- Crucial delay to let the server process the "Close" before we "Open" again
            task.wait(0.18) 
        end
        
        isDropping = false
        ToggleBtn.Text = "START MULTI-DROP"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 220, 150)
        forceCleanExit()
    end)
end)

