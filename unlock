RunService.Heartbeat:Connect(function()
    if not PlayerMovement then return end

    -- [[ GOD MODE V2 & NO KNOCKBACK ]]
    if Settings.GodModeV2 then
        PlayerMovement.Sensor = false -- Disable tile damage/physics
        PlayerMovement.OnCollideBind = false -- Disable collision damage/knockback
        
