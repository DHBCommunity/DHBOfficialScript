local function getTotalHoldingAmount(targetId)
    local total = 0
    if not targetId then return 0 end
    for _, stack in pairs(InvModule.Stacks) do
        if stack and stack.Id == targetId then
            total = total + (stack.Amount or 0)
        end
    end
    return total
end

