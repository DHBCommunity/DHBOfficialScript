-- Reusable Collection Function
local function CollectItem(item)
    if not Settings.Magnet or Settings.AntiCollect then return end
    if not item:IsA("BasePart") or item:GetAttribute("t") then return end

    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local distance = (root.Position - item.Position).Magnitude
    if distance <= Settings.MagnetRange then
        item:SetAttribute("t", true) -- Mark immediately to prevent double-collecting

        task.spawn(function()
            -- Visual Polish: Smoothly fly to player
            item.CanCollide = false
            item.Anchored = true
            
            local startPos = item.Position
            local duration = 0.25 -- Faster flight (0.25s) for responsiveness
            local startTick = tick()
            
            while tick() - startTick < duration do
                -- Stop if item is destroyed or player toggles Anti-Collect
                if not item or not item.Parent or not root or Settings.AntiCollect then break end
                
                local pc = (tick() - startTick) / duration
                item.Position = startPos:Lerp(root.Position, pc)
                RunService.Heartbeat:Wait()
            end

            -- Final Server Notification
            if item and item.Parent and not Settings.AntiCollect then
                MovementRemote:FireServer(Vector2.new(item.Position.X, item.Position.Y))
            end
        end)
    end
end

