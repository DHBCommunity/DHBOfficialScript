local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    -- [[ MOVEMENT PACKET INTERCEPT ]]
    if self.Name == Player.Name and method == "FireServer" then
        local parent = self.Parent
        if parent and parent.Name == "PlayerMovementPackets" then
            
            -- ANTI-COLLECT & GHOST MODE (Priority: Deletes Packets)
            if Settings.AntiCollect or Settings.GhostMode then
                return nil
            end
            
            -- PING FAKE (RUBBER BANDING)
            if Settings.PingFake then
                -- Store the packet instead of sending it
                table.insert(Settings.PingBuffer, {Remote = self, Args = args})
                
                -- When buffer hits 15 packets, release the "burst"
                if #Settings.PingBuffer >= 15 then
                    for _, packet in ipairs(Settings.PingBuffer) do
                        OldNamecall(packet.Remote, unpack(packet.Args))
                    end
                    Settings.PingBuffer = {} -- Clear buffer
                end
                
                return nil -- Prevent the original single packet from sending
            end
        end
    end

    -- [[ GOD MODE BYPASS ]]
    if (Settings.GodMode or Settings.GodModeV2) and self.Name == "PlayerHurtMe" and method == "FireServer" then 
        warn("Erik: Damage Packet Blocked (" .. tostring(args[1]) .. ")")
        return nil 
    end

    return OldNamecall(self, ...)
end)

